# TrueYield Environment Variables
# Copy this file to .env and fill in the values

# Server ports
HTTP_PORT=80
HTTPS_PORT=443
PORT=8080

# Infura API key (get one at https://infura.io)
REACT_APP_INFURA_KEY=your_infura_key_here

# Infura key with Polygon (Matic) support
REACT_APP_MATIC_INFURA_KEY=your_matic_infura_key_here

# Harvest API key (publicly available)
REACT_APP_EXTERNAL_API_KEY=your_external_api_key_here

# UI API key (publicly available)
REACT_APP_API_KEY=your_api_key_here

# ZapperFi API key
REACT_APP_ZAPPERFI_API_KEY=your_zapperfi_api_key_here

# App mode: 'prod' for production, 'debug' for debug logging
REACT_APP_MODE=prod
